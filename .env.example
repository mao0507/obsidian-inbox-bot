# 分類模式：auto（預設，自動偵測）| cli（強制用本機 agent CLI）| api（強制用 Anthropic API key）
CLASSIFIER_MODE=auto

# auto/cli 模式用哪個指令做分類。
# 留空的話會依序自動偵測電腦上裝了 claude、cursor-agent、agent 哪一個，用找到的第一個。
# 想強制指定某一個，填指令名稱即可，例如 cursor-agent（Cursor CLI 也可以叫 "agent"，兩個是同一支）。
# 只要這台電腦上該指令已安裝且登入過，就不需要另外申請/付費 API key。
AGENT_CLI_COMMAND=

# 呼叫 AGENT_CLI_COMMAND 時要帶的參數（用空白分隔）。
# 留空的話，claude / cursor-agent / agent 都有內建預設值，通常不用改。
# 其他 CLI 或想自訂行為（例如加 --model）才需要填。
AGENT_CLI_ARGS=

# 只有 CLASSIFIER_MODE=api（或自動偵測時電腦上找不到任何 agent CLI）才需要填這個。
# 申請位置：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 用哪個 Claude 模型做分類（只影響 api 模式；cli 模式用你 CLI 本身設定的模型）
CLAUDE_MODEL=claude-sonnet-4-5

# Telegram bot token — 跟 @BotFather 申請
TELEGRAM_BOT_TOKEN=xxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# 只有這些 Telegram user ID 能傳訊息給 bot、收到 bot 回覆，其他人傳訊息會被拒絕。
# 用逗號分隔多個 ID，例如：TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# 留空 = 不限制，任何人只要知道這個 bot 都能用（不建議）。
# 不知道自己的 ID？先留空啟動 bot，傳 /whoami 或 /id 給它，它會回覆你的 ID，再填進來重啟。
TELEGRAM_ALLOWED_USER_IDS=

# 你的 Obsidian vault 資料夾完整路徑
# Windows 範例: C:\Users\User\Documents\Obsidian Vault
VAULT_PATH=C:\Users\User\Documents\Obsidian Vault

# Web UI 監聽的 port
PORT=3838

# 筆記自動同步到 git（選用）。填了這個之後，每次新增筆記（或你手動搬動 vault 裡的檔案後
# 下一次有新筆記寫入時）都會自動 git add + commit + push 到這個 remote。
# 留空 = 完全不啟用，筆記只會寫在本機 vault，行為跟以前一樣。
# 範例（HTTPS）：https://github.com/your-name/obsidian-vault.git
# 範例（SSH）：  git@github.com:your-name/obsidian-vault.git
# 用 HTTPS 的話電腦要先設定好 git 帳密快取（例如 Git Credential Manager）；
# 用 SSH 的話要先設定好 SSH key 並且能免密碼連到這個 remote，
# 這支程式是背景執行、不會跳出視窗讓你輸入帳號密碼，沒設定好的話 push 會直接失敗
# （筆記還是會正常存在本機，只是不會同步上去，錯誤訊息會印在終端機）。
VAULT_GIT_REMOTE=

# VAULT_GIT_REMOTE 要推到哪個分支，預設 main。
VAULT_GIT_BRANCH=main

# /notebook 指令（選用）：用 NotebookLM 做真正的網路研究，不是這支程式的 npm 依賴，
# 是另外要裝的獨立 Python CLI（notebooklm-py），見 README「用 NotebookLM 做深度研究」。
# 找不到這個指令時 /notebook 會回覆說明、不影響其他功能。
# 指令名稱不是 notebooklm（例如自訂了別名）才需要填，通常留空即可。
NOTEBOOKLM_COMMAND=

# fast（預設）：幾十秒內完成，來源較少、回覆較快。
# deep：Google 的 Deep Research，來源更完整，但可能要幾分鐘到半小時，Telegram 訊息會等比較久。
NOTEBOOKLM_RESEARCH_MODE=fast

# NotebookLM 登入過期時，自動嘗試從這個瀏覽器重新讀取登入 cookie 來修復（不用開互動視窗），
# 前提是這個瀏覽器裡本身要有一個還有效的 Google 登入 session。留空則不會嘗試這個 fallback，
# 過期時只會提示你手動執行 notebooklm login。預設 chrome，見 README「登入過期怎麼辦」。
NOTEBOOKLM_LOGIN_BROWSER=chrome
